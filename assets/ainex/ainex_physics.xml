<!-- assets/ainex/ainex_physics.xml -->
<mujoco model="ainex">
  <compiler angle="radian"/>

  <option timestep="0.002" gravity="0 0 -9.81" iterations="100" tolerance="1e-8" solver="Newton"/>

  <default>
    <joint damping="0.05" armature="0.02" limited="true"/>

    <!-- Contact defaults
         - condim=6 enables torsional + rolling friction (helps feet stop "ice skating")
         - friction is (sliding torsional rolling)
         - slightly softer contact helps stability during standing/settling -->
    <geom friction="1.2 0.03 0.003" solref="0.03 1" solimp="0.90 0.95 0.001" condim="6"/>

    <!-- Foot-specific contact tuning (higher sliding friction, still stable) -->
    <default class="foot">
      <geom friction="2.2 0.05 0.005" condim="6"
            solref="0.02 1" solimp="0.90 0.95 0.001"/>
    </default>

    <!-- Position actuator safety defaults
         NOTE: per-actuator forcerange overrides below are what really fix playback -->
    <position ctrllimited="true" ctrlrange="-2.09 2.09" forcelimited="true" forcerange="-600 600"/>
  </default>

  <asset>
    <mesh name="body_link" content_type="model/stl" file="meshes/body_link.STL"/>
    <mesh name="r_hip_yaw_link" content_type="model/stl" file="meshes/r_hip_yaw_link.STL"/>
    <mesh name="r_hip_roll_link" content_type="model/stl" file="meshes/r_hip_roll_link.STL"/>
    <mesh name="r_hip_pitch_link" content_type="model/stl" file="meshes/r_hip_pitch_link.STL"/>
    <mesh name="r_knee_link" content_type="model/stl" file="meshes/r_knee_link.STL"/>
    <mesh name="r_ank_pitch_link" content_type="model/stl" file="meshes/r_ank_pitch_link.STL"/>
    <mesh name="r_ank_roll_link" content_type="model/stl" file="meshes/r_ank_roll_link.STL"/>
    <mesh name="l_hip_yaw_link" content_type="model/stl" file="meshes/l_hip_yaw_link.STL"/>
    <mesh name="l_hip_roll_link" content_type="model/stl" file="meshes/l_hip_roll_link.STL"/>
    <mesh name="l_hip_pitch_link" content_type="model/stl" file="meshes/l_hip_pitch_link.STL"/>
    <mesh name="l_knee_link" content_type="model/stl" file="meshes/l_knee_link.STL"/>
    <mesh name="l_ank_pitch_link" content_type="model/stl" file="meshes/l_ank_pitch_link.STL"/>
    <mesh name="l_ank_roll_link" content_type="model/stl" file="meshes/l_ank_roll_link.STL"/>
    <mesh name="head_pan_link" content_type="model/stl" file="meshes/head_pan_link.STL"/>
    <mesh name="head_tilt_link" content_type="model/stl" file="meshes/head_tilt_link.STL"/>
    <mesh name="r_sho_pitch_link" content_type="model/stl" file="meshes/r_sho_pitch_link.STL"/>
    <mesh name="r_sho_roll_link" content_type="model/stl" file="meshes/r_sho_roll_link.STL"/>
    <mesh name="r_el_pitch_link" content_type="model/stl" file="meshes/r_el_pitch_link.STL"/>
    <mesh name="r_el_yaw_link" content_type="model/stl" file="meshes/r_el_yaw_link.STL"/>
    <mesh name="r_gripper_link" content_type="model/stl" file="meshes/r_gripper_link.STL"/>
    <mesh name="l_sho_pitch_link" content_type="model/stl" file="meshes/l_sho_pitch_link.STL"/>
    <mesh name="l_sho_roll_link" content_type="model/stl" file="meshes/l_sho_roll_link.STL"/>
    <mesh name="l_el_pitch_link" content_type="model/stl" file="meshes/l_el_pitch_link.STL"/>
    <mesh name="l_el_yaw_link" content_type="model/stl" file="meshes/l_el_yaw_link.STL"/>
    <mesh name="l_gripper_link" content_type="model/stl" file="meshes/l_gripper_link.STL"/>
  </asset>

  <contact>
    <!-- Adjacent leg exclusions (right) -->
    <exclude body1="r_hip_yaw_link"   body2="r_hip_roll_link"/>
    <exclude body1="r_hip_roll_link"  body2="r_hip_pitch_link"/>
    <exclude body1="r_hip_pitch_link" body2="r_knee_link"/>
    <exclude body1="r_knee_link"      body2="r_ank_pitch_link"/>
    <exclude body1="r_ank_pitch_link" body2="r_ank_roll_link"/>

    <!-- Adjacent leg exclusions (left) -->
    <exclude body1="l_hip_yaw_link"   body2="l_hip_roll_link"/>
    <exclude body1="l_hip_roll_link"  body2="l_hip_pitch_link"/>
    <exclude body1="l_hip_pitch_link" body2="l_knee_link"/>
    <exclude body1="l_knee_link"      body2="l_ank_pitch_link"/>
    <exclude body1="l_ank_pitch_link" body2="l_ank_roll_link"/>

    <!-- Feet should not collide with their own chain -->
    <exclude body1="r_ank_roll_link" body2="r_knee_link"/>
    <exclude body1="r_ank_roll_link" body2="r_hip_pitch_link"/>
    <exclude body1="r_ank_roll_link" body2="r_hip_roll_link"/>
    <exclude body1="r_ank_roll_link" body2="r_hip_yaw_link"/>

    <exclude body1="l_ank_roll_link" body2="l_knee_link"/>
    <exclude body1="l_ank_roll_link" body2="l_hip_pitch_link"/>
    <exclude body1="l_ank_roll_link" body2="l_hip_roll_link"/>
    <exclude body1="l_ank_roll_link" body2="l_hip_yaw_link"/>

    <!-- Torso vs upper legs (often always close) -->
    <exclude body1="torso" body2="r_hip_yaw_link"/>
    <exclude body1="torso" body2="r_hip_roll_link"/>
    <exclude body1="torso" body2="r_hip_pitch_link"/>
    <exclude body1="torso" body2="l_hip_yaw_link"/>
    <exclude body1="torso" body2="l_hip_roll_link"/>
    <exclude body1="torso" body2="l_hip_pitch_link"/>

    <!-- Adjacent arm exclusions -->
    <exclude body1="r_sho_pitch_link" body2="r_sho_roll_link"/>
    <exclude body1="r_sho_roll_link"  body2="r_el_pitch_link"/>
    <exclude body1="r_el_pitch_link"  body2="r_el_yaw_link"/>
    <exclude body1="r_el_yaw_link"    body2="r_gripper_link"/>

    <exclude body1="l_sho_pitch_link" body2="l_sho_roll_link"/>
    <exclude body1="l_sho_roll_link"  body2="l_el_pitch_link"/>
    <exclude body1="l_el_pitch_link"  body2="l_el_yaw_link"/>
    <exclude body1="l_el_yaw_link"    body2="l_gripper_link"/>

    <!-- Arms vs torso (prevents constant chatter) -->
    <exclude body1="torso" body2="r_sho_pitch_link"/>
    <exclude body1="torso" body2="r_sho_roll_link"/>
    <exclude body1="torso" body2="l_sho_pitch_link"/>
    <exclude body1="torso" body2="l_sho_roll_link"/>

    <!-- Foot contacts exclusions -->
    <exclude body1="r_ank_roll_link" body2="l_ank_roll_link"/>
  </contact>

  <worldbody>
    <geom name="ref_line_x" type="box" pos="1 0 0.001" size="1 0.002 0.001" rgba="0.2 0.2 0.2 1" contype="0" conaffinity="0"/>
    <geom name="ref_line_y" type="box" pos="0 1 0.001" size="0.002 1 0.001" rgba="0.2 0.2 0.2 1" contype="0" conaffinity="0"/>

    <light name="key" directional="true" pos="0 0 3" dir="0 0 -1" diffuse="2 2 2" specular="1 1 1"/>
    <light name="fill" directional="false" pos="2 2 2" diffuse="1 1 1" specular="0.5 0.5 0.5"/>
    <light name="rim" directional="true" pos="0 0 3" dir="-1 -1 -1" diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2"/>

    <!-- Slightly higher floor friction; condim=6 matches default -->
    <geom name="floor" type="plane" pos="0 0 0" size="5 5 0.1" rgba="0.9 0.9 0.9 1"
          friction="1.1 0.35 0.35" condim="6" contype="1" conaffinity="1"/>

    <body name="torso" pos="0 0 0.05">
      <freejoint/>

      <!-- Visual mesh only -->
      <geom type="mesh" contype="0" conaffinity="0" rgba="0.1 0.1 0.1 1" mesh="body_link"/>

      <!-- Torso collision model (simple) -->
      <geom name="torso_col" type="box" pos="0 0 0.06" size="0.045 0.030 0.060"
            rgba="0 0 0 0" contype="1" conaffinity="1"/>

      <!-- Electronics ballast: approximate Pi + battery mass in back cavity -->
      <body name="electronics_ballast" pos="-0.030 0 0.070">
        <!-- Start with ~0.18 kg total; tune later -->
        <inertial pos="0 0 0" mass="0.18" diaginertia="0.00012 0.00012 0.00012"/>
        <!-- Visual/placeholder shape; non-colliding -->
        <geom name="electronics_ballast_geom"
              type="box" size="0.040 0.025 0.020"
              rgba="0.2 0.2 0.2 0.2"
              contype="0" conaffinity="0"/>
      </body>

      <!-- RIGHT LEG -->
      <body name="r_hip_yaw_link" pos="0 -0.029 0">
        <inertial pos="-3.08089e-05 0.00125727 -0.00137107" quat="0.685451 0.035864 -0.0116524 0.727142" mass="0.032" diaginertia="2.27792e-05 1.75538e-05 8.97703e-06"/>
