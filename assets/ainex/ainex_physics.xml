                  <geom type="mesh" contype="0" conaffinity="0" rgba="0.1 0.1 0.1 1" mesh="r_ank_roll_link"/>

                  <!-- Foot contact:
                       Use two boxes (heel + toe) to guarantee full ground support even if the toe sticks out.
                       Adjust X positions/sizes if your mesh footprint differs. -->
                  <geom class="foot" name="r_heel_col" type="box"
